# =========================================================
# SyedOS Environment Variable Template
# Copy this file to .env.local for local development.
# Never place real passwords or API keys in this file.
# =========================================================

# Application
NODE_ENV=development
NEXT_PUBLIC_SITE_NAME=SyedOS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# PostgreSQL
DATABASE_URL=postgresql://syedos_user:replace_with_password@localhost:5432/syedos

# Payload CMS
PAYLOAD_SECRET=replace_with_a_long_random_secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Initial owner account
ADMIN_EMAIL=replace_with_owner_email
ADMIN_NAME=Syed Mohiuddin

# Google Gemini
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=replace_with_model_name

# GitHub integration
GITHUB_USERNAME=syedmohiuddin106-dot
GITHUB_TOKEN=replace_with_optional_github_token

# Email service
EMAIL_FROM=replace_with_verified_sender_email
EMAIL_API_KEY=replace_with_email_service_api_key

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=disabled
ANALYTICS_KEY=replace_with_analytics_key

# Media and object storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=replace_with_bucket_name
STORAGE_REGION=replace_with_region
STORAGE_ACCESS_KEY=replace_with_storage_access_key
STORAGE_SECRET_KEY=replace_with_storage_secret_key

# Security and rate limiting
RATE_LIMIT_ENABLED=true
CONTACT_FORM_ENABLED=false
AI_ASSISTANT_ENABLED=false

# Deployment
DEPLOYMENT_ENVIRONMENT=development